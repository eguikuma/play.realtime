{
  "name": "@play.realtime/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "pnpm -F @play.realtime/contracts -F @play.realtime/transport-protocol run build && next build",
    "start": "next start -p 3000",
    "verify": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:list": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@play.realtime/contracts": "workspace:*",
    "@play.realtime/transport-protocol": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@play.realtime/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
